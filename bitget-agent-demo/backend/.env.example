PORT=3001

# DeepSeek 双档：Lite(Flash 最便宜) / Premium(Pro 决策·风控·退出)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_LITE_MODEL=deepseek-v4-flash
DEEPSEEK_PREMIUM_MODEL=deepseek-v4-pro
# 兼容旧变量名
DEEPSEEK_PERCEPTION_MODEL=deepseek-v4-flash
DEEPSEEK_DECISION_MODEL=deepseek-v4-pro

# 感知层 — FRED 宏观 + Finnhub 新闻/报价
FRED_API_KEY=your-fred-api-key
FINNHUB_API_KEY=your-finnhub-api-key

# Bitget Demo API（Paper Trading · UTA V3）
# 可从 ../demo-bot/.env 复制，或从 Bitget 控制台获取 Demo Key
BITGET_API_KEY=your-demo-api-key
BITGET_SECRET_KEY=your-demo-secret-key
BITGET_PASSPHRASE=your-passphrase

# 国内访问 Bitget 需代理（Clash 默认 7897）
NODE_USE_ENV_PROXY=1
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
